# ─── Required ────────────────────────────────────────────────────────────────
# OpenRouter key — powers the chat/answer LLM. Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Google Gemini key — powers RAG embeddings (text-embedding-004).
# OpenRouter has no embeddings endpoint, so this is separate and free. Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Optional (sensible defaults shown) ──────────────────────────────────────
# Answer model, routed through OpenRouter. Any OpenRouter model id works.
OPENROUTER_MODEL=openai/gpt-4o-mini

# Cheaper model used for query-rewriting + topic tagging + handoff summaries.
OPENROUTER_UTILITY_MODEL=openai/gpt-4o-mini

# Gemini embedding model + dimensions.
EMBEDDING_MODEL=models/gemini-embedding-2
EMBEDDING_DIM=768

# Escalate when top retrieval cosine similarity falls below this (0..1).
# Tuned against the seeded Nimbus KB so out-of-scope queries escalate.
CONFIDENCE_THRESHOLD=0.30

# How many chunks to retrieve per query.
RAG_TOP_K=6

# Shown to OpenRouter for attribution (optional).
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=Nimbus Support
